{
  "metadata": [
    {
      "src": [
        {
          "files": ["src/KubeMQ.Sdk/KubeMQ.Sdk.csproj"],
          "src": ".."
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net8.0"
      },
      "filter": "filterConfig.yml"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["articles/**.md", "toc.yml", "*.md"]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "dest": "_site",
    "globalMetadataFiles": [],
    "globalMetadata": {
      "_appTitle": "KubeMQ .NET SDK",
      "_appFooter": "KubeMQ .NET SDK API Reference",
      "_enableSearch": true
    },
    "template": ["default", "modern"]
  }
}
